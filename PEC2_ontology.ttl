@prefix : <http://www.owl-ontologies.com/ns#> .
@prefix ns: <http://www.owl-ontologies.com/ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.owl-ontologies.com/ns#> .

<http://www.owl-ontologies.com/ns> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.owl-ontologies.com/ns#addressesIncident
ns:addressesIncident rdf:type owl:ObjectProperty ;
                     rdfs:domain ns:CorrectiveAction ;
                     rdfs:range ns:Incident ;
                     rdfs:comment "The corrective action involves the mentioned incident." ;
                     rdfs:label "addresses incident" .


###  http://www.owl-ontologies.com/ns#hasManufacturer
ns:hasManufacturer rdf:type owl:ObjectProperty ;
                   rdfs:domain ns:MedicalDevice ;
                   rdfs:range ns:Manufacturer ;
                   rdfs:comment "Device is made by the manufacturer." ;
                   rdfs:label "has manufacturer" .


###  http://www.owl-ontologies.com/ns#hasRiskClass
ns:hasRiskClass rdf:type owl:ObjectProperty ;
                rdfs:domain ns:MedicalDevice ;
                rdfs:range ns:RiskClass ;
                rdfs:comment "Regulatory classification of the device." ;
                rdfs:label "has risk class" .


###  http://www.owl-ontologies.com/ns#involvesDevice
ns:involvesDevice rdf:type owl:ObjectProperty ;
                  rdfs:domain ns:Incident ;
                  rdfs:range ns:MedicalDevice ;
                  rdfs:comment "Incident is caused by the device." ;
                  rdfs:label "involves device" .


###  http://www.owl-ontologies.com/ns#manifestsRisk
ns:manifestsRisk rdf:type owl:ObjectProperty ;
                 rdfs:domain ns:Incident ;
                 rdfs:range ns:Risk ;
                 rdfs:comment "Incident is an instance of the risk." ;
                 rdfs:label "manifests risk" .


###  http://www.owl-ontologies.com/ns#targetsDevice
ns:targetsDevice rdf:type owl:ObjectProperty ;
                 rdfs:comment "The corrective action involves the following device" ;
                 rdfs:label "targets device" .


#################################################################
#    Data properties
#################################################################

###  http://www.owl-ontologies.com/ns#eventDate
ns:eventDate rdf:type owl:DatatypeProperty ;
             rdfs:domain ns:Incident ;
             rdfs:range xsd:dateTime ;
             rdfs:comment "The date and time when the incident occurred." ;
             rdfs:label "event date" .


###  http://www.owl-ontologies.com/ns#hasUDI
ns:hasUDI rdf:type owl:DatatypeProperty ;
          rdfs:domain ns:MedicalDevice ;
          rdfs:range xsd:string ;
          rdfs:comment "Unique Device Identification string for the medical device." ;
          rdfs:label "has UDI" .


#################################################################
#    Classes
#################################################################

###  http://www.owl-ontologies.com/ns#ActiveDevice
ns:ActiveDevice rdf:type owl:Class ;
                rdfs:subClassOf ns:MedicalDevice ;
                rdfs:comment "Device has moving parts or live batteries." ;
                rdfs:label "Active Device" .


###  http://www.owl-ontologies.com/ns#ClassI
ns:ClassI rdf:type owl:Class ;
          rdfs:subClassOf ns:RiskClass ;
          rdfs:comment "Low risk" ;
          rdfs:label "Class I" .


###  http://www.owl-ontologies.com/ns#ClassIII
ns:ClassIII rdf:type owl:Class ;
            rdfs:subClassOf ns:RiskClass ;
            rdfs:comment "High Risk" ;
            rdfs:label "Class III" .


###  http://www.owl-ontologies.com/ns#ClassIIa
ns:ClassIIa rdf:type owl:Class ;
            rdfs:subClassOf ns:RiskClass ;
            rdfs:comment "Mid-Low Risk" ;
            rdfs:label "Class IIa" .


###  http://www.owl-ontologies.com/ns#ClassIIb
ns:ClassIIb rdf:type owl:Class ;
            rdfs:subClassOf ns:RiskClass ;
            rdfs:comment "Mid-High Risk" ;
            rdfs:label "Class IIb" .


###  http://www.owl-ontologies.com/ns#CorrectiveAction
ns:CorrectiveAction rdf:type owl:Class ;
                    rdfs:subClassOf ns:EUDAMEDEntity ;
                    rdfs:comment "Actions taken to mitigate risks or incidents." ;
                    rdfs:label "Corrective Action" .


###  http://www.owl-ontologies.com/ns#CriticalRisk
ns:CriticalRisk rdf:type owl:Class ;
                rdfs:subClassOf ns:Risk ;
                rdfs:comment "Major malfunction or shutdown of the device." ;
                rdfs:label "Critical Risk" .


###  http://www.owl-ontologies.com/ns#EUDAMEDEntity
ns:EUDAMEDEntity rdf:type owl:Class ;
                 rdfs:subClassOf owl:Thing ;
                 rdfs:comment "All daughter classes will be subinstances of EUDAMED entities." ;
                 rdfs:label "EUDAMED Entity" .


###  http://www.owl-ontologies.com/ns#ImplantableDevice
ns:ImplantableDevice rdf:type owl:Class ;
                     rdfs:subClassOf ns:MedicalDevice ;
                     rdfs:comment "Device is inserted into the patient's body." ;
                     rdfs:label "Implantable Device" .


###  http://www.owl-ontologies.com/ns#InVitroDevice
ns:InVitroDevice rdf:type owl:Class ;
                 rdfs:subClassOf ns:MedicalDevice ;
                 rdfs:comment "Device is meant for laboratory use." ;
                 rdfs:label "In Vitro Device" .


###  http://www.owl-ontologies.com/ns#Incident
ns:Incident rdf:type owl:Class ;
            rdfs:subClassOf ns:EUDAMEDEntity ;
            rdfs:comment "Entity is an incident described in incidentes.csv." ;
            rdfs:label "Incident" .


###  http://www.owl-ontologies.com/ns#Manufacturer
ns:Manufacturer rdf:type owl:Class ;
                rdfs:subClassOf ns:EUDAMEDEntity ;
                rdfs:comment "Company that manufactures the medical device." ;
                rdfs:label "Manufacturer" .


###  http://www.owl-ontologies.com/ns#MedicalDevice
ns:MedicalDevice rdf:type owl:Class ;
                 rdfs:subClassOf ns:EUDAMEDEntity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty ns:hasManufacturer ;
                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass ns:Manufacturer
                                 ] ;
                 rdfs:comment "Entity is a device described in dispositivos.csv." ;
                 rdfs:label "Medical Device" .


###  http://www.owl-ontologies.com/ns#ModerateRisk
ns:ModerateRisk rdf:type owl:Class ;
                rdfs:subClassOf ns:Risk ;
                rdfs:comment "Minor malfunction of the device." ;
                rdfs:label "Moderate Risk" .


###  http://www.owl-ontologies.com/ns#NearMissincident
ns:NearMissincident rdf:type owl:Class ;
                    rdfs:subClassOf ns:Incident ;
                    rdfs:comment "Incident caused a scare with no serious injury." ;
                    rdfs:label "Near Miss incident" .


###  http://www.owl-ontologies.com/ns#ReusableDevice
ns:ReusableDevice rdf:type owl:Class ;
                  rdfs:subClassOf ns:MedicalDevice ;
                  rdfs:comment "Device can be used more than once." ;
                  rdfs:label "Reusable Device" .


###  http://www.owl-ontologies.com/ns#Risk
ns:Risk rdf:type owl:Class ;
        rdfs:subClassOf ns:EUDAMEDEntity ;
        rdfs:comment "Entity is a risk described in riesgos.csv." ;
        rdfs:label "Risk" .


###  http://www.owl-ontologies.com/ns#RiskClass
ns:RiskClass rdf:type owl:Class ;
             rdfs:subClassOf ns:EUDAMEDEntity ;
             rdfs:comment "Regulatory classification of the device." ;
             rdfs:label "Risk Class" .


###  http://www.owl-ontologies.com/ns#SeriousIncident
ns:SeriousIncident rdf:type owl:Class ;
                   rdfs:subClassOf ns:Incident ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty ns:hasManufacturer ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass ns:Manufacturer
                                   ] ;
                   rdfs:comment "Incident caused severe injury or death." ;
                   rdfs:label "Serious Incident" .


###  http://www.owl-ontologies.com/ns#SeriousRisk
ns:SeriousRisk rdf:type owl:Class ;
               rdfs:subClassOf ns:Risk ;
               rdfs:comment "Severe malfunction of the device." ;
               rdfs:label "Serious Risk" .


###  http://www.w3.org/2002/07/owl#Thing
owl:Thing rdf:type owl:Class ;
          rdfs:label "Thing" .


#################################################################
#    Individuals
#################################################################

###  http://www.owl-ontologies.com/ns#DEV-001
ns:DEV-001 rdf:type owl:NamedIndividual ,
                    ns:ActiveDevice ,
                    ns:ImplantableDevice ;
           ns:hasManufacturer ns:MAN-001 ;
           rdfs:comment "Device Model." ;
           rdfs:label "HeartMate 3 LVAD" .


###  http://www.owl-ontologies.com/ns#FSCA-001
ns:FSCA-001 rdf:type owl:NamedIndividual ,
                     ns:CorrectiveAction ;
            ns:addressesIncident ns:INC-001 ;
            rdfs:comment "Safety alert issued for protocol update." ;
            rdfs:label "FSCA-001" .


###  http://www.owl-ontologies.com/ns#INC-001
ns:INC-001 rdf:type owl:NamedIndividual ,
                    ns:SeriousIncident ;
           ns:involvesDevice ns:DEV-001 ;
           ns:manifestsRisk ns:RSK-001 ;
           rdfs:comment "Embolic stroke incident" ;
           rdfs:label "INC-001" .


###  http://www.owl-ontologies.com/ns#MAN-001
ns:MAN-001 rdf:type owl:NamedIndividual ,
                    ns:Manufacturer ;
           rdfs:comment "DBPedia entry." ;
           rdfs:label "Medtronic plc" .


###  http://www.owl-ontologies.com/ns#RSK-001
ns:RSK-001 rdf:type owl:NamedIndividual ,
                    ns:CriticalRisk ;
           rdfs:comment "Device failure - electrical leading to shutdown." ;
           rdfs:label "RSK-001" .


#################################################################
#    Rules
#################################################################

<urn:swrl:var#d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#c> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#i> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#r> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> ns:Incident ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> ns:manifestsRisk ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#r>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#classPredicate> ns:CriticalRisk ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#r>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> ns:SeriousIncident ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> ns:Incident ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> ns:involvesDevice ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#d>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#classPredicate> ns:ImplantableDevice ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> ns:SeriousIncident ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> ns:MedicalDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> ns:hasRiskClass ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#c>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#classPredicate> ns:ClassIII ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#c>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
