<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.owl-ontologies.com/ns#"
     xml:base="http://www.owl-ontologies.com/ns"
     xmlns:ns="http://www.owl-ontologies.com/ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://www.owl-ontologies.com/ns"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.owl-ontologies.com/ns#addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/ns#addressesIncident">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
        <rdfs:comment>The corrective action involves the mentioned incident.</rdfs:comment>
        <rdfs:label>addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/ns#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/ns#hasManufacturer">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/ns#Manufacturer"/>
        <rdfs:comment>Device is made by the manufacturer.</rdfs:comment>
        <rdfs:label>has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/ns#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/ns#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/ns#RiskClass"/>
        <rdfs:comment>Regulatory classification of the device.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/ns#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/ns#involvesDevice">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:comment>Incident is caused by the device.</rdfs:comment>
        <rdfs:label>involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/ns#manifestsRisk -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/ns#manifestsRisk">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/ns#Risk"/>
        <rdfs:comment>Incident is an instance of the risk.</rdfs:comment>
        <rdfs:label>manifests risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/ns#targetsDevice -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/ns#targetsDevice">
        <rdfs:comment>The corrective action involves the following device</rdfs:comment>
        <rdfs:label>targets device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.owl-ontologies.com/ns#eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/ns#eventDate">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date and time when the incident occurred.</rdfs:comment>
        <rdfs:label>event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.owl-ontologies.com/ns#hasUDI -->


    <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/ns#hasUDI">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique Device Identification string for the medical device.</rdfs:comment>
        <rdfs:label>has UDI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.owl-ontologies.com/ns#ActiveDevice -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:comment>Device has moving parts or live batteries.</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ClassI -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#RiskClass"/>
        <rdfs:comment>Low risk</rdfs:comment>
        <rdfs:label>Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ClassIII -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#RiskClass"/>
        <rdfs:comment>High Risk</rdfs:comment>
        <rdfs:label>Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ClassIIa -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#RiskClass"/>
        <rdfs:comment>Mid-Low Risk</rdfs:comment>
        <rdfs:label>Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ClassIIb -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#RiskClass"/>
        <rdfs:comment>Mid-High Risk</rdfs:comment>
        <rdfs:label>Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#CorrectiveAction -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#EUDAMEDEntity"/>
        <rdfs:comment>Actions taken to mitigate risks or incidents.</rdfs:comment>
        <rdfs:label>Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#CriticalRisk -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#CriticalRisk">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#Risk"/>
        <rdfs:comment>Major malfunction or shutdown of the device.</rdfs:comment>
        <rdfs:label>Critical Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#EUDAMEDEntity -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#EUDAMEDEntity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>All daughter classes will be subinstances of EUDAMED entities.</rdfs:comment>
        <rdfs:label>EUDAMED Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ImplantableDevice -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:comment>Device is inserted into the patient&apos;s body.</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#InVitroDevice -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#InVitroDevice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:comment>Device is meant for laboratory use.</rdfs:comment>
        <rdfs:label>In Vitro Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#Incident -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#Incident">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#EUDAMEDEntity"/>
        <rdfs:comment>Entity is an incident described in incidentes.csv.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#Manufacturer -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#EUDAMEDEntity"/>
        <rdfs:comment>Company that manufactures the medical device.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#MedicalDevice -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#EUDAMEDEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/ns#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.owl-ontologies.com/ns#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Entity is a device described in dispositivos.csv.</rdfs:comment>
        <rdfs:label>Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ModerateRisk -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ModerateRisk">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#Risk"/>
        <rdfs:comment>Minor malfunction of the device.</rdfs:comment>
        <rdfs:label>Moderate Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#NearMissincident -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#NearMissincident">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
        <rdfs:comment>Incident caused a scare with no serious injury.</rdfs:comment>
        <rdfs:label>Near Miss incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#ReusableDevice -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#ReusableDevice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
        <rdfs:comment>Device can be used more than once.</rdfs:comment>
        <rdfs:label>Reusable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#Risk -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#Risk">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#EUDAMEDEntity"/>
        <rdfs:comment>Entity is a risk described in riesgos.csv.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#RiskClass -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#RiskClass">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#EUDAMEDEntity"/>
        <rdfs:comment>Regulatory classification of the device.</rdfs:comment>
        <rdfs:label>Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#SeriousIncident -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/ns#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.owl-ontologies.com/ns#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Incident caused severe injury or death.</rdfs:comment>
        <rdfs:label>Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/ns#SeriousRisk -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/ns#SeriousRisk">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/ns#Risk"/>
        <rdfs:comment>Severe malfunction of the device.</rdfs:comment>
        <rdfs:label>Serious Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2002/07/owl#Thing -->


    <owl:Class rdf:about="http://www.w3.org/2002/07/owl#Thing">
        <rdfs:label>Thing</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.owl-ontologies.com/ns#DEV-001 -->


    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/ns#DEV-001">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/ns#ActiveDevice"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/ns#ImplantableDevice"/>
        <hasManufacturer rdf:resource="http://www.owl-ontologies.com/ns#MAN-001"/>
        <rdfs:comment>Device Model.</rdfs:comment>
        <rdfs:label>HeartMate 3 LVAD</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.owl-ontologies.com/ns#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/ns#FSCA-001">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/ns#CorrectiveAction"/>
        <addressesIncident rdf:resource="http://www.owl-ontologies.com/ns#INC-001"/>
        <rdfs:comment>Safety alert issued for protocol update.</rdfs:comment>
        <rdfs:label>FSCA-001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.owl-ontologies.com/ns#INC-001 -->


    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/ns#INC-001">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/ns#SeriousIncident"/>
        <involvesDevice rdf:resource="http://www.owl-ontologies.com/ns#DEV-001"/>
        <manifestsRisk rdf:resource="http://www.owl-ontologies.com/ns#RSK-001"/>
        <rdfs:comment>Embolic stroke incident</rdfs:comment>
        <rdfs:label>INC-001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.owl-ontologies.com/ns#MAN-001 -->


    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/ns#MAN-001">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/ns#Manufacturer"/>
        <rdfs:comment>DBPedia entry.</rdfs:comment>
        <rdfs:label>Medtronic plc</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.owl-ontologies.com/ns#RSK-001 -->


    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/ns#RSK-001">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/ns#CriticalRisk"/>
        <rdfs:comment>Device failure - electrical leading to shutdown.</rdfs:comment>
        <rdfs:label>RSK-001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Rules
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="urn:swrl:var#d">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl:var#c">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl:var#i">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="urn:swrl:var#r">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
                        <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.owl-ontologies.com/ns#involvesDevice"/>
                                <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                                <swrl:argument2 rdf:resource="urn:swrl:var#d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#ImplantableDevice"/>
                                        <swrl:argument1 rdf:resource="urn:swrl:var#d"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#SeriousIncident"/>
                        <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#Incident"/>
                        <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.owl-ontologies.com/ns#manifestsRisk"/>
                                <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                                <swrl:argument2 rdf:resource="urn:swrl:var#r"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#CriticalRisk"/>
                                        <swrl:argument1 rdf:resource="urn:swrl:var#r"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#SeriousIncident"/>
                        <swrl:argument1 rdf:resource="urn:swrl:var#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.owl-ontologies.com/ns#MedicalDevice"/>
                        <swrl:argument1 rdf:resource="urn:swrl:var#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.owl-ontologies.com/ns#hasRiskClass"/>
                                <swrl:argument1 rdf:resource="urn:swrl:var#d"/>
                                <swrl:argument2 rdf:resource="urn:swrl:var#c"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
